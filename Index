<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 32 32%27%3E%3Crect width=%2732%27 height=%2732%27 rx=%278%27 fill=%27%236366f1%27/%3E%3C/svg%3E">
    <title>SponsorBridge — Connecting Student Clubs with Sponsors</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="logo">
           <span class="logo-mark" aria-hidden="true"></span>SponsorBridge
        </div>

        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>

        <div class="nav-links" id="nav-links">
            <a href="index.html" class="active">Home</a>
            <a href="opportunities.html">Opportunities</a>
            <a href="about.html">About</a>
            <a href="how-it-works.html">How It Works</a>
        </div>
        <div class="nav-actions">
            <button id="theme-toggle" aria-label="Toggle theme">◐</button>
            <button id="Login-btn" data-modal="login">Login</button>
            <button id="SignUp-btn" data-modal="signup">Sign Up</button>
        </div>
    </nav>

    <section class="hero">
        <span class="eyebrow">For clubs &amp; sponsors, together</span>
        <h1>Connecting Student Clubs with Sponsors</h1>

        <p>
            Helping clubs find funding for events,
            competitions, and projects — while giving sponsors
            a direct line to the students they want to reach.
        </p>

        <div class="hero-buttons">
            <button class="club-btn" data-modal="signup" data-role="club">I'm a Club</button>
            <button class="sponsor-btn" data-modal="signup" data-role="sponsor">I'm a Sponsor</button>
        </div>
    </section>

    <section class="stats-strip" aria-label="Platform impact">
        <div class="stat">
            <span class="stat-number">240+</span>
            <span class="stat-label">Clubs funded</span>
        </div>
        <div class="stat">
            <span class="stat-number">85</span>
            <span class="stat-label">Active sponsors</span>
        </div>
        <div class="stat">
            <span class="stat-number">$1.2M</span>
            <span class="stat-label">Raised for campus projects</span>
        </div>
        <div class="stat">
            <span class="stat-number">96%</span>
            <span class="stat-label">Matches renewed next term</span>
        </div>
    </section>

    <section class="teaser-grid">
        <a href="how-it-works.html" class="teaser-card">
            <span class="eyebrow">How it works</span>
            <h2>Three steps from idea to funded</h2>
            <p>Post a request, get matched with a sponsor, and release funds against real milestones.</p>
            <span class="teaser-link">See the full process →</span>
        </a>

        <a href="opportunities.html" class="teaser-card">
            <span class="eyebrow">Live now</span>
            <h2>Browse open opportunities</h2>
            <p>Clubs across tech, arts, sports, business, and community are looking for sponsors today.</p>
            <span class="teaser-link">View opportunities →</span>
        </a>

        <a href="about.html" class="teaser-card">
            <span class="eyebrow">About</span>
            <h2>Why SponsorBridge exists</h2>
            <p>Built to close the gap between clubs chasing funding and sponsors looking for real reach.</p>
            <span class="teaser-link">Read more →</span>
        </a>
    </section>

    <section class="cta-banner">
        <h2>Ready to build your bridge?</h2>
        <p>It takes less than five minutes to create a profile.</p>
        <div class="hero-buttons">
            <button class="club-btn" data-modal="signup" data-role="club">I'm a Club</button>
            <button class="sponsor-btn" data-modal="signup" data-role="sponsor">I'm a Sponsor</button>
        </div>
    </section>

    <footer class="site-footer">
        <div class="footer-top">
            <div class="footer-brand">
                <span class="logo"><span class="logo-mark" aria-hidden="true"></span>SponsorBridge</span>
                <p>The bridge between student clubs and the sponsors who want to back them.</p>
            </div>
            <div class="footer-links">
                <div class="footer-col">
                    <h4>Platform</h4>
                    <a href="opportunities.html">Opportunities</a>
                    <a href="how-it-works.html">How It Works</a>
                    <a href="about.html">About</a>
                </div>
                <div class="footer-col">
                    <h4>Account</h4>
                    <a href="#" data-modal="login">Login</a>
                    <a href="#" data-modal="signup">Sign Up</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <span>&copy; 2026 SponsorBridge. All rights reserved.</span>
        </div>
    </footer>

    <!-- Auth modal (shared by Login / Sign Up) -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
            <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>

            <div class="modal-tabs">
                <button class="modal-tab" data-tab="login">Login</button>
                <button class="modal-tab" data-tab="signup">Sign Up</button>
            </div>

            <h2 id="modal-title" class="modal-title">Welcome back</h2>

            <form id="auth-form" novalidate>
                <div class="form-field signup-only">
                    <label for="full-name">Full name</label>
                    <input type="text" id="full-name" name="full-name" autocomplete="name">
                </div>

                <div class="form-field signup-only">
                    <label>I am a...</label>
                    <div class="role-select">
                        <button type="button" class="role-option" data-role-option="club">Club</button>
                        <button type="button" class="role-option" data-role-option="sponsor">Sponsor</button>
                    </div>
                </div>

                <div class="form-field">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" autocomplete="email" required>
                </div>

                <div class="form-field">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" autocomplete="current-password" required minlength="8">
                </div>

                <p class="form-error" id="form-error" hidden></p>

                <button type="submit" class="submit-btn" id="submit-btn">Log in</button>
            </form>

            <p class="modal-switch">
                <span id="switch-prompt">Don't have an account?</span>
                <button type="button" id="switch-btn">Sign up</button>
            </p>
        </div>
    </div>

    <script src="js/main.js" defer></script>
</body>
</html>
